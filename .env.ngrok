# ngrok Configuration
# Leave these empty or undefined if you want random ngrok domains
# If you have a paid plan with reserved domains, set them here:
# NGROK_DOMAIN_API=your-api-domain.ngrok-free.app
# NGROK_DOMAIN_CUSTOMER=your-customer-domain.ngrok-free.app
# NGROK_DOMAIN_DRIVER=your-driver-domain.ngrok-free.app

# Your ngrok authtoken (get from: https://dashboard.ngrok.com/get-started/your-authtoken)
# NGROK_AUTHTOKEN=your_auth_token_here
