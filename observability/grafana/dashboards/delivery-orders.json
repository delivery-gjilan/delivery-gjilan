{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Orders Created (per 5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"delivery-api\"} | json | service=`OrderService` | msg=~`.*order.*created.*|.*creating order.*` [5m]))",
          "legendFormat": "Orders Created",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "drawStyle": "bars", "fillOpacity": 40, "lineWidth": 1, "showPoints": "never" }
        },
        "overrides": []
      }
    },
    {
      "title": "Order Status Transitions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (msg) (count_over_time({job=\"delivery-api\"} | json | service=`OrderService` [5m]))",
          "legendFormat": "{{msg}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      }
    },
    {
      "title": "Payment / Settlement Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"delivery-api\"} | json | service=`FinancialService` | msg=~`.*settlement created.*` [5m]))",
          "legendFormat": "Settlements Created",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({job=\"delivery-api\"} | json | service=`FinancialService` | level=`error` [5m]))",
          "legendFormat": "Payment Errors",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Payment Errors" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "Driver Assignment Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"delivery-api\"} | json | msg=~`.*assign.*driver.*|.*driver.*assigned.*` [5m]))",
          "legendFormat": "Driver Assignments",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({job=\"delivery-api\"} | json | msg=~`.*driver.*reject.*|.*no driver.*` [5m]))",
          "legendFormat": "Assignment Failures",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Assignment Failures" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "Driver Watchdog Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (msg) (count_over_time({job=\"delivery-api\"} | json | service=`DriverWatchdog` [5m]))",
          "legendFormat": "{{msg}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      }
    },
    {
      "title": "Driver Heartbeat Activity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"delivery-api\"} | json | service=`DriverHeartbeat` [1m]))",
          "legendFormat": "Heartbeat Events/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      }
    },
    {
      "title": "Auth Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"delivery-api\"} | json | service=`AuthService` | msg=~`.*login.*|.*register.*|.*verification.*` [5m]))",
          "legendFormat": "Auth Attempts",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({job=\"delivery-api\"} | json | service=`AuthService` | level=`error` [5m]))",
          "legendFormat": "Auth Errors",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Auth Errors" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "Promotion Engine Activity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"delivery-api\"} | json | service=`PromotionEngine` [5m]))",
          "legendFormat": "Promotion Evaluations",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({job=\"delivery-api\"} | json | service=`PromotionService` | level=`error` or level=`warn` [5m]))",
          "legendFormat": "Promotion Errors/Warnings",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      }
    },
    {
      "title": "All Delivery Errors",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"delivery-api\"} | json | level=`error` or level=`fatal` | service=~`OrderService|FinancialService|DriverWatchdog|DriverHeartbeat`",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "prettifyLogMessage": true
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["delivery", "orders", "drivers"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Delivery & Orders",
  "uid": "delivery-orders"
}
