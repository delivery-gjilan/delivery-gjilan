{
  "name": "api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:api:preflight",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:harness:settlement": "tsx --env-file=.env scripts/run-settlement-harness.ts",
    "test:api:preflight": "npm run test:harness:settlement",
    "test:api:strict": "npm run typecheck && npm run test:harness:settlement",
    "dev:raw": "nodemon --watch src --ext ts,graphql --exec \"npm run codegen && tsx --env-file=.env src/index.ts\" --node-args=\"--max-old-space-size=2048\"",
    "dev": "npm run dev:raw",
    "dev:preflight": "npm run test:api:preflight && npm run dev:raw",
    "build": "echo 'skip build'",
    "start": "node --max-old-space-size=2048 node_modules/.bin/tsx src/index.ts",
    "start:test": "npm run test:api:preflight && npm run start:raw",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "eslint . -c eslint.config.mjs",
    "lint:fix": "eslint . --fix -c eslint.config.mjs",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:formatted": "npm run codegen && npm run lint:fix && npm run format:fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env database/seed.ts",
    "db:seed:stress": "tsx --env-file=.env scripts/seed-stress-test.ts",
    "test:stress": "powershell -ExecutionPolicy Bypass -File tests/k6/run.ps1",
    "test:stress:smoke": "powershell -ExecutionPolicy Bypass -File tests/k6/run.ps1 -Smoke",
    "test:stress:analyze": "node tests/k6/analyze.js",
    "db:reset": "bash scripts/reset-db.sh",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eddeee888/gcg-typescript-resolver-files": "^0.11.0",
    "@faker-js/faker": "^10.1.0",
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/typescript": "^5.0.6",
    "@graphql-codegen/typescript-react-apollo": "^4.3.3",
    "@graphql-codegen/typescript-resolvers": "^5.1.4",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/coverage-v8": "^4.1.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "graphql-scalars": "^1.25.0",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.947.0",
    "@escape.tech/graphql-armor": "^3.2.0",
    "@graphql-tools/schema": "^10.0.30",
    "@graphql-tools/utils": "^10.11.0",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@types/multer": "^2.0.0",
    "@types/ws": "^8.18.1",
    "agora-access-token": "^2.0.4",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.0",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "expo-server-sdk": "^6.0.0",
    "expo-updates": "~29.0.16",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.6.1",
    "graphql": "^16.12.0",
    "graphql-ws": "^6.0.6",
    "graphql-yoga": "^5.17.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-loki": "^3.0.0",
    "postgres": "^3.4.8",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.10.0",
    "resend": "^6.10.0",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "ws": "^8.18.3",
    "zod": "^4.1.13"
  }
}
