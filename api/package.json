{
  "name": "api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon --watch src --ext ts,graphql --exec \"npm run codegen && tsx --env-file=.env src/index.ts\"",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "eslint . -c eslint.config.mjs",
    "lint:fix": "eslint . --fix -c eslint.config.mjs",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:formatted": "npm run codegen && npm run lint:fix && npm run format:fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env database/seed.ts",
    "db:reset": "bash scripts/reset-db.sh",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eddeee888/gcg-typescript-resolver-files": "^0.11.0",
