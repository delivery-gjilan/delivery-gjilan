{
    "name": "api",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "dev": "nodemon --watch src --ext ts,graphql --exec \"npm run codegen && tsx --env-file=.env src/index.ts\"",
        "build": "tsc",
        "start": "node --env-file=.env dist/index.js",
        "format": "prettier . --check",
        "format:fix": "prettier . --write",
        "lint": "eslint . -c eslint.config.mjs",
        "lint:fix": "eslint . --fix -c eslint.config.mjs",
        "codegen": "graphql-codegen --config codegen.ts",
        "codegen:formatted": "npm run codegen && npm run lint:fix && npm run format:fix",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "devDependencies": {
        "@eddeee888/gcg-typescript-resolver-files": "^0.11.0",
        "@graphql-codegen/cli": "^6.1.0",
        "@graphql-codegen/typescript": "^5.0.6",
        "@graphql-codegen/typescript-resolvers": "^5.1.4",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^24.10.1",
        "@types/pg": "^8.15.6",
        "@typescript-eslint/eslint-plugin": "^8.48.1",
        "@typescript-eslint/parser": "^8.48.1",
        "drizzle-kit": "^0.31.8",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-n": "^17.23.1",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-promise": "^7.2.1",
        "graphql-scalars": "^1.25.0",
        "nodemon": "^3.1.11",
        "prettier": "^3.7.3",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.44.7",
        "express": "^5.2.1",
        "graphql": "^16.12.0",
        "graphql-yoga": "^5.17.1",
        "pg": "^8.16.3"
    }
}
