NODE_ENV=development
DB_URL=postgresql://postgres:postgres@localhost:8090/delivery-gjilan-db-local
PORT=4000
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
REFRESH_TOKEN_SECRET=your-separate-refresh-token-secret-change-this

── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:8082,http://localhost:8083,http://localhost:8084

── Redis ──
REDIS_URL=redis://localhost:6379

── Mapbox ──
MAPBOX_TOKEN=

── Observability ──
LOG_LEVEL=debug

── Stress Testing (local only, never set in production) ──
STRESS_TEST_SECRET=local-stress-bypass-secret

── Email (Resend) ──
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@deliverygjilan.com
PUBLIC_API_URL=http://localhost:4000

── Live Activity APNs ──
# Apple Developer -> Certificates, Identifiers & Profiles -> Keys
# Create or reuse a key with Apple Push Notifications service (APNs) enabled.
LIVE_ACTIVITY_APNS_KEY_ID=
# Apple Developer team ID (matches your iOS team / membership team ID)
LIVE_ACTIVITY_APNS_TEAM_ID=
# Contents of the downloaded .p8 key. Preserve literal \n when storing in env managers.
LIVE_ACTIVITY_APNS_PRIVATE_KEY=
# Optional override. Defaults to com.artshabani.mobilecustomer.
LIVE_ACTIVITY_APNS_BUNDLE_ID=
# sandbox for development, production for live deploys
LIVE_ACTIVITY_APNS_ENV=