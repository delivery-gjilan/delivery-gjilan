default_platform(:ios)

platform :ios do
  desc "Build and upload a new TestFlight build"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY"),
      is_key_content_base64: true,
      duration: 1200,
      in_house: false
    )

    # ── Workspace / project discovery ──────────────────────────────────────────
    # Fastfile runs from within mobile-customer/ios/; all paths are relative to there.

    workspace_path = ENV["IOS_WORKSPACE_PATH"].to_s
    project_path   = ENV["IOS_PROJECT_PATH"].to_s

    if workspace_path.empty?
      workspace_path = Dir["**/*.xcworkspace"]
                         .reject { |p| p.include?(".xcodeproj/") }
                         .sort
                         .first.to_s
    end

    if project_path.empty?
      project_path = Dir["**/*.xcodeproj"]
                       .reject { |p| p.include?("Pods.xcodeproj") }
                       .sort
                       .first.to_s
    end

    UI.user_error!("No .xcworkspace or .xcodeproj found.") if workspace_path.empty? && project_path.empty?

    # Prefer workspace (CocoaPods build includes all pods)
    scheme_name = ENV["IOS_SCHEME"].to_s
    if scheme_name.empty?
      scheme_name = workspace_path.empty? \
        ? File.basename(project_path, ".xcodeproj") \
        : File.basename(workspace_path, ".xcworkspace")
    end

    # ── Signing configuration ───────────────────────────────────────────────────
    team_id             = ENV.fetch("IOS_TEAM_ID",             "87K8YXG5V8")
    app_bundle_id       = ENV.fetch("IOS_APP_BUNDLE_ID",       "com.anonymous.mobilecustomer")
    ext_bundle_id       = ENV.fetch("IOS_EXTENSION_BUNDLE_ID", "com.anonymous.mobilecustomer.DeliveryLiveActivityExtension")
    app_profile_name    = ENV.fetch("IOS_MAIN_PROFILE_NAME")
    ext_profile_name    = ENV.fetch("IOS_EXTENSION_PROFILE_NAME")
    app_profile_uuid    = ENV["IOS_MAIN_PROFILE_UUID"].to_s
    ext_profile_uuid    = ENV["IOS_EXTENSION_PROFILE_UUID"].to_s

    UI.user_error!("Missing IOS_MAIN_PROFILE_NAME")      if app_profile_name.to_s.empty?
    UI.user_error!("Missing IOS_EXTENSION_PROFILE_NAME") if ext_profile_name.to_s.empty?

    build_path    = File.expand_path("../build",     __dir__)
    buildlog_path = File.expand_path("../buildlogs", __dir__)

    # ── Apply manual code-signing to the .xcodeproj ─────────────────────────────
    # update_code_signing_settings modifies CODE_SIGN_STYLE, CODE_SIGN_IDENTITY and
    # PROVISIONING_PROFILE_SPECIFIER for each named target.
    unless project_path.empty?
      [
        { targets: ["mobilecustomer"],              bundle_id: app_bundle_id, profile: app_profile_name },
        { targets: ["DeliveryLiveActivityExtension"], bundle_id: ext_bundle_id,  profile: ext_profile_name }
      ].each do |cfg|
        update_code_signing_settings(
          use_automatic_signing: false,
          path: project_path,
          team_id: team_id,
          code_sign_identity: "Apple Distribution",
          targets: cfg[:targets],
          bundle_identifier: cfg[:bundle_id],
          profile_name: cfg[:profile]
        )
      end

      # Belt-and-suspenders: also assign profiles by UUID (unambiguous, avoids name-match issues).
      # update_project_provisioning sets PROVISIONING_PROFILE in the build settings to the UUID.
      unless app_profile_uuid.empty?
        update_project_provisioning(
          xcodeproj: project_path,
          profile: File.expand_path("~/Library/MobileDevice/Provisioning Profiles/#{app_profile_uuid}.mobileprovision"),
          target_filter: "mobilecustomer",
          build_configuration: "Release",
          code_signing_identity: "Apple Distribution"
        )
      end

      unless ext_profile_uuid.empty?
        update_project_provisioning(
          xcodeproj: project_path,
          profile: File.expand_path("~/Library/MobileDevice/Provisioning Profiles/#{ext_profile_uuid}.mobileprovision"),
          target_filter: "DeliveryLiveActivityExtension",
          build_configuration: "Release",
          code_signing_identity: "Apple Distribution"
        )
      end
    end

    # ── Sync extension version to match main app ──────────────────────────────
    # Expo prebuild names the extension plist "<Target>-Info.plist"; use Dir.glob to find
    # the actual file regardless of naming convention.
    app_info_plist = Dir.glob("mobilecustomer/Info.plist").first ||
                     Dir.glob("mobilecustomer/*-Info.plist").first

    ext_info_plist = Dir.glob("DeliveryLiveActivityExtension/Info.plist").first ||
                     Dir.glob("DeliveryLiveActivityExtension/*-Info.plist").first

    if app_info_plist && ext_info_plist
      app_version = get_info_plist_value(path: app_info_plist, key: "CFBundleShortVersionString")
      app_build   = get_info_plist_value(path: app_info_plist, key: "CFBundleVersion")
      set_info_plist_value(path: ext_info_plist, key: "CFBundleShortVersionString", value: app_version)
      set_info_plist_value(path: ext_info_plist, key: "CFBundleVersion",            value: app_build)
      UI.success("Synced extension to version #{app_version} (#{app_build})")
    else
      UI.important("Info.plist not found — skipping version sync.")
      UI.important("  app_info_plist: #{app_info_plist.inspect}")
      UI.important("  ext_info_plist: #{ext_info_plist.inspect}")
    end

    # ── Build (archive + export) ────────────────────────────────────────────────
    gym_options = {
      scheme:           scheme_name,
      clean:            true,
      export_method:    "app-store",
      output_directory: build_path,
      output_name:      "app-testflight.ipa",
      buildlog_path:    buildlog_path,
      xcargs:           "DEVELOPMENT_TEAM=#{team_id} CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution' -allowProvisioningUpdates",
      export_options: {
        method:       "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          app_bundle_id => app_profile_name,
          ext_bundle_id => ext_profile_name
        }
      },
      export_xcargs: "-allowProvisioningUpdates",
      result_bundle: true
    }

    gym_options[:workspace] = workspace_path unless workspace_path.empty?
    gym_options[:project]   = project_path   if workspace_path.empty? && !project_path.empty?

    ipa_path = gym(**gym_options)

    # ── Upload to TestFlight ────────────────────────────────────────────────────
    pilot(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
