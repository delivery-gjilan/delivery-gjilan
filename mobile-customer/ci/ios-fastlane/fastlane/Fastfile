default_platform(:ios)

platform :ios do
  desc "Build and upload a new TestFlight build"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY"),
      is_key_content_base64: true,
      duration: 1200,
      in_house: false
    )

    workspace_path = ENV["IOS_WORKSPACE_PATH"]
    project_path = ENV["IOS_PROJECT_PATH"]

    if workspace_path.to_s.empty?
      workspace_candidates = Dir["**/*.xcworkspace"].sort.reject { |path| path.include?(".xcodeproj/") }
      workspace_path = workspace_candidates.first
    end

    if project_path.to_s.empty?
      project_candidates = Dir["**/*.xcodeproj"].sort.reject { |path| path.include?("Pods.xcodeproj") }
      project_path = project_candidates.first
    end

    UI.user_error!("No .xcworkspace or .xcodeproj found in the ios directory.") unless workspace_path || project_path

    scheme_name = ENV["IOS_SCHEME"]
    if scheme_name.to_s.empty?
      scheme_name =
        if workspace_path
          File.basename(workspace_path, ".xcworkspace")
        else
          File.basename(project_path, ".xcodeproj")
        end
    end

    build_path = File.expand_path("../build", __dir__)
    buildlog_path = File.expand_path("../buildlogs", __dir__)
    team_id = ENV["IOS_TEAM_ID"] || "87K8YXG5V8"
    app_bundle_id = ENV["IOS_APP_BUNDLE_ID"] || "com.anonymous.mobilecustomer"
    extension_bundle_id = ENV["IOS_EXTENSION_BUNDLE_ID"] || "com.anonymous.mobilecustomer.DeliveryLiveActivityExtension"
    app_profile_name = ENV["IOS_MAIN_PROFILE_NAME"]
    extension_profile_name = ENV["IOS_EXTENSION_PROFILE_NAME"]

    UI.user_error!("Missing IOS_MAIN_PROFILE_NAME in environment") if app_profile_name.to_s.empty?
    UI.user_error!("Missing IOS_EXTENSION_PROFILE_NAME in environment") if extension_profile_name.to_s.empty?

    unless project_path.to_s.empty?
      update_code_signing_settings(
        use_automatic_signing: false,
        path: project_path,
        team_id: team_id,
        code_sign_identity: "Apple Distribution",
        targets: ["mobilecustomer"],
        bundle_identifier: app_bundle_id,
        profile_name: app_profile_name
      )

      update_code_signing_settings(
        use_automatic_signing: false,
        path: project_path,
        team_id: team_id,
        code_sign_identity: "Apple Distribution",
        targets: ["DeliveryLiveActivityExtension"],
        bundle_identifier: extension_bundle_id,
        profile_name: extension_profile_name
      )
    end

    gym_options = {
      scheme: scheme_name,
      clean: true,
      export_method: "app-store",
      output_directory: build_path,
      output_name: "app-testflight.ipa",
      buildlog_path: buildlog_path,
      xcargs: "DEVELOPMENT_TEAM=#{team_id} CODE_SIGN_STYLE=Manual -allowProvisioningUpdates",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          app_bundle_id => app_profile_name,
          extension_bundle_id => extension_profile_name
        }
      },
      export_xcargs: "-allowProvisioningUpdates"
    }

    if workspace_path
      gym_options[:workspace] = workspace_path
    else
      gym_options[:project] = project_path
    end

    ipa_path = gym(**gym_options)

    pilot(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
